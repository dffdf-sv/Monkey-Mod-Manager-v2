<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="600"
        x:Class="MonkeModManager.MainWindow"
        Title="MonkeModManager"
        MinWidth="700" MinHeight="500"
        Icon="avares://MonkeModManager/Assets/mmm-ico.png"
        Name="MainWin"
        TransparencyLevelHint="AcrylicBlur"
        >

        <Grid Name="MainGrid">
                <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Header Bar -->
                <Border Grid.Row="0" Name="HeaderBar" Padding="16,12" BorderThickness="0,0,0,1">
                        <Grid ColumnDefinitions="Auto, *, Auto, Auto">
                                <Image Grid.Column="0"
                                       Source="Assets/mmm-ico.png"
                                       Height="32"
                                       Width="32"
                                       VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1"
                                          Text="Monke Mod Manager"
                                          Name="TitleText"
                                          FontSize="20"
                                          FontWeight="SemiBold"
                                          VerticalAlignment="Center"
                                          Margin="12,0,0,0"/>
                                <Button Grid.Column="2" Name="DropDownBtn"
                                        Background="Transparent"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Padding="10,6"
                                        VerticalAlignment="Center"
                                        Click="ShowDropdown_Click"
                                        Cursor="Hand">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                                <Image Name="MenuImage" Height="18" Width="18"/>
                                                <TextBlock Text="Menu" FontSize="13" VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <Button.ContextMenu>
                                                <ContextMenu x:Name="BtnDropdown">
                                                        <MenuItem Header="Install From Disk" Click="InstallFromDiskBtn_OnClick"/>
                                                        <MenuItem Header="Change Theme" Click="SwitchTheme"/>
                                                        <MenuItem Header="Mods Folder" Click="OpenModsFolder_OnClick"/>
                                                        <MenuItem Header="Game Folder" Click="OpenGamePath_OnClick"/>
                                                        <MenuItem Header="Launch Game (Steam Only)" Click="LaunchBtn_OnClick"/>
                                                        <MenuItem Name="DisableEnable" Click="DisableAll_OnClick"/>
                                                        <MenuItem Header="Reset Game Path" Click="ResetGamePath_OnClick"/>
                                                        <MenuItem Header="Config Editor" Click="Config_OnClick"/>
                                                </ContextMenu>
                                        </Button.ContextMenu>
                                </Button>
                        </Grid>
                </Border>

                <!-- Search Bar -->
                <Border Grid.Row="1" Name="SearchBar" Padding="16,8">
                        <Grid ColumnDefinitions="*, Auto">
                                <TextBox Grid.Column="0"
                                         Name="SearchBox"
                                         Watermark="Search mods..."
                                         TextChanged="SearchBox_OnTextChanged"
                                         CornerRadius="8"
                                         Height="36"
                                         VerticalContentAlignment="Center"
                                         Padding="12,0"/>
                                <ComboBox Grid.Column="1"
                                          Width="160"
                                          Margin="12,0,0,0"
                                          SelectedIndex="0"
                                          SelectionChanged="SortBox_OnSelectionChanged"
                                          Name="SortBox"
                                          HorizontalContentAlignment="Center">
                                        <ComboBoxItem Content="Group" />
                                        <ComboBoxItem Content="Alphabetical (A-Z)" />
                                        <ComboBoxItem Content="Author" />
                                </ComboBox>
                        </Grid>
                </Border>

                <ProgressBar Grid.Row="2"
                             Name="ProgressBarAtStart"
                             Minimum="0"
                             Maximum="100"
                             Height="4"
                             IsVisible="False"
                             VerticalAlignment="Top"/>

                <!-- Mods List -->
                <Border Grid.Row="2"
                        Name="ModsThingy"
                        Margin="0">
                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled"
                                      Padding="16,8">
                                <ItemsControl Name="ItemControl0">
                                        <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                        <StackPanel Spacing="12" />
                                                </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                </ItemsControl>
                        </ScrollViewer>
                </Border>

                <!-- Status Bar -->
                <Border Grid.Row="3"
                        Name="MsgBox0Border"
                        Padding="16,10"
                        BorderThickness="0,1,0,0">
                        <TextBlock Name="MessageBox0"
                                  Text="Ready"
                                  FontSize="12"
                                  VerticalAlignment="Center"/>
                </Border>
        </Grid>
</Window>